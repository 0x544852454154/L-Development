# Copy this file to .env and fill in your values

# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# The client ID of your bot application (used to register slash commands)
CLIENT_ID=your_bot_client_id_here

# Default prefix for message commands (each server can override with the prefix command)
DEFAULT_PREFIX=!

# The ID of the bot owner (full access to owner-only commands)
OWNER_ID=your_discord_user_id_here

# Optional: a default premium status for new servers (true/false)
DEFAULT_PREMIUM=false
